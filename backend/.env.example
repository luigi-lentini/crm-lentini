# Variabili di ambiente per il backend CRM LENTINI
# Copia questo file in .env e compila i valori

# Server
PORT=3001
NODE_ENV=development

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=password
DB_NAME=crmlentini

# Oppure usa DATABASE_URL per Render/produzione:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL (per CORS)
FRONTEND_URL=http://localhost:5173
